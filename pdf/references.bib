@article{LIU2026106893,
title = {Full-view digital pavement reconstruction for practical traffic scenarios through altitude-robust vehicle detection and traffic-adaptive optimization},
journal = {Automation in Construction},
volume = {186},
pages = {106893},
year = {2026},
issn = {0926-5805},
doi = {https://doi.org/10.1016/j.autcon.2026.106893},
url = {https://www.sciencedirect.com/science/article/pii/S0926580526001342},
author = {Han Liu and Ronggui Ma},
keywords = {High-quality photogrammetric reconstruction, Practical traffic scenarios, Unnamed aerial vehicle (UAV), Object detection, Structure from motion (SfM), Stereo vision},
abstract = {High-quality digital pavement reconstruction is essential for transportation infrastructure management, yet faces challenges from vehicle occlusions, traffic interference in practical scenarios. This paper proposes a full-view digital pavement reconstruction system, integrating UAV-based image acquisition, an Altitude-Robust Vehicle Detection Network (AR-VDN), and traffic-adaptive multi-view optimization. The AR-VDN achieves an AP75 of 94.25% at 115.45 FPS. The reconstructed models under dynamic traffic conditions achieve depth measurement errors below 1% and improve overall processing efficiency by over 20% compared to traditional Structure-from-Motion workflows. Compared to traditional manual or semi-automated methods, this system significantly improves operational efficiency and reduces labor costs. Additionally, this research facilitates the development for intelligent asset management, predictive maintenance, and automated construction, providing a geometric foundation for the practical adoption of digital twin platforms.}
}

